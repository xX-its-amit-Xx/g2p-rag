# Anthropic API key for LLM generation (required for --generate)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (only needed if using OpenAI embeddings)
OPENAI_API_KEY=sk-...

# NCBI API key for higher ClinVar rate limits (optional but recommended)
NCBI_API_KEY=

# Data directory for cache and ChromaDB (default: ./data)
G2P_DATA_DIR=data

# Embedding model (default: sentence-transformers/all-MiniLM-L6-v2)
# Alternative: text-embedding-3-large
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM model for generation
LLM_MODEL=claude-sonnet-4-6
